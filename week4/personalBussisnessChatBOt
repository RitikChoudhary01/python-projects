from groq import Groq
import os
from dotenv import load_dotenv

load_dotenv()
api_key = os.getenv("GROQ_API_KEY")
if not api_key:
     raise RuntimeError ("please check env api..")
    
client = Groq(api_key=api_key)

system_prompt = """
You are customer support for "Ritik's Electronics Store"

Business info:
- Timing: 10 AM to 9 PM, all days
- Delivery: Yes, within 10km free
- Payment: Cash, UPI, Cards accepted
- Products: Phones, Laptops, Accessories
- Location: Near City Mall, Warangal

Rules:
- Be polite and helpful
- Keep responses short 
- If question is not about above info, say "Let me connect you to staff"
"""

def getRespponse(customer_question):
    response = client.chat.completions.create(
        model="llama-3.3-70b-versatile",
        messages=[
           { "role": "system", "content": system_prompt},
           { "role": "user", "content": customer_question}
        ],
        temperature= 0.3,
        stream=True
        
    )
    return response

while True:
    
    user = input("enter the you qury : ")
    response = getRespponse(user)
        
        
     
    print("bot: ", end="", flush=True)

    for chunk in response:
        content = chunk.choices[0].delta.content
        if content:
            print(content, end="", flush=True)

    print()


